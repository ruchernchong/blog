NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Database Configuration
DATABASE_URL=

# GitHub Integration
GH_ACCESS_TOKEN=

# Redis Configuration
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# IP Salting
IP_SALT=

# BetterAuth Configuration
BETTER_AUTH_SECRET=
# For production, set it to something else. e.g. https://auth.example.com
BETTER_AUTH_URL="http://localhost:3000"

# OAuth Providers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudflare R2 Storage
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=https://assets.ruchern.dev

# PostHog (Vercel integration, EU Cloud)
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# PostHog Query API (server-side reads — separate from Vercel integration)
POSTHOG_PROJECT_ID=
POSTHOG_API_KEY=

# MCP Server (Remote Access)
BLOG_MCP_AUTH_TOKEN=
MCP_REVALIDATE_SECRET=
# Optional override for the Worker to call the Next.js revalidation endpoint.
# Defaults to ${NEXT_PUBLIC_BASE_URL}/api/mcp/revalidate when omitted.
MCP_REVALIDATE_URL=

# Alchemy Cloudflare IaC
CLOUDFLARE_API_TOKEN=
ALCHEMY_PASSWORD=
ALCHEMY_STATE_TOKEN=
