{
  "name": "ruchern-dev",
  "version": "1.16.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --filter=@workspace/web",
    "dev:docs": "turbo run @workspace/docs#dev",
    "build": "turbo run build",
    "start": "pnpm --filter @workspace/web start",
    "test": "turbo run test",
    "test:watch": "pnpm --filter @workspace/web test:watch",
    "test:coverage": "turbo run test:coverage",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "typecheck": "turbo run typecheck",
    "docs:dev": "pnpm --filter @workspace/docs dev",
    "docs:build": "pnpm --filter @workspace/docs build",
    "docs:typecheck": "pnpm --filter @workspace/docs typecheck",
    "auth:generate": "pnpm --filter @workspace/web auth:generate",
    "db:drop": "pnpm --filter @workspace/web db:drop",
    "db:generate": "pnpm --filter @workspace/web db:generate",
    "db:migrate": "pnpm --filter @workspace/web db:migrate",
    "db:push": "pnpm --filter @workspace/web db:push",
    "db:pull": "pnpm --filter @workspace/web db:pull",
    "db:check": "pnpm --filter @workspace/web db:check",
    "db:up": "pnpm --filter @workspace/web db:up",
    "db:studio": "pnpm --filter @workspace/web db:studio",
    "db:seed": "pnpm --filter @workspace/web db:seed",
    "usage:ingest": "pnpm --filter @workspace/web usage:ingest",
    "usage:ingest:prod": "pnpm --filter @workspace/web usage:ingest:prod",
    "mcp": "pnpm --filter @workspace/mcp mcp",
    "prepare": "husky",
    "release": "semantic-release"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@commitlint/types": "^20.5.0",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/exec": "7.1.0",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.8",
    "@semantic-release/release-notes-generator": "14.1.1",
    "conventional-changelog-conventionalcommits": "^9.1.0",
    "husky": "^9.1.6",
    "lint-staged": "^16.2.7",
    "portless": "0.10.2",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "semantic-release": "25.0.3",
    "turbo": "2.9.16"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,css,md,mdx}": "biome check --write --no-errors-on-unmatched"
  },
  "packageManager": "pnpm@11.1.2"
}
