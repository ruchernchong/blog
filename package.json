{
  "name": "ruchern-dev",
  "version": "1.28.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "turbo run @workspace/web#dev",
    "dev:docs": "turbo run @workspace/docs#dev",
    "build": "turbo run build",
    "build:web": "turbo run @workspace/web#build",
    "start": "turbo run start",
    "start:web": "turbo run @workspace/web#start",
    "test": "turbo run test",
    "test:watch": "turbo run @workspace/web#test:watch",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "typecheck": "turbo run typecheck",
    "docs:dev": "turbo run @workspace/docs#dev",
    "docs:build": "turbo run @workspace/docs#build",
    "docs:typecheck": "turbo run @workspace/docs#typecheck",
    "auth:generate": "turbo run @workspace/web#auth:generate",
    "db:drop": "turbo run @workspace/web#db:drop",
    "db:generate": "turbo run @workspace/web#db:generate",
    "db:migrate": "turbo run @workspace/web#db:migrate",
    "db:push": "turbo run @workspace/web#db:push",
    "db:pull": "turbo run @workspace/web#db:pull",
    "db:check": "turbo run @workspace/web#db:check",
    "db:up": "turbo run @workspace/web#db:up",
    "db:studio": "turbo run @workspace/web#db:studio",
    "db:seed": "turbo run @workspace/web#db:seed",
    "usage:ingest": "turbo run @workspace/web#usage:ingest",
    "usage:ingest:prod": "turbo run @workspace/web#usage:ingest:prod",
    "mcp": "turbo run @workspace/mcp#mcp",
    "prepare": "husky",
    "release": "semantic-release"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@commitlint/types": "^20.5.0",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/exec": "7.1.0",
    "@semantic-release-extras/verified-git-commit": "^1.0.11",
    "@semantic-release/github": "12.0.8",
    "@semantic-release/release-notes-generator": "14.1.1",
    "conventional-changelog-conventionalcommits": "^9.1.0",
    "husky": "^9.1.6",
    "lint-staged": "^16.2.7",
    "portless": "0.10.2",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "semantic-release": "25.0.3",
    "turbo": "2.10.4"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,css,md,mdx}": "biome check --write --no-errors-on-unmatched"
  },
  "packageManager": "pnpm@11.5.3"
}
