{
  "mcpServers": {
    "blog": {
      "type": "http",
      "url": "https://ruchern.dev/api/mcp",
      "headers": {
        "Authorization": "Bearer ${BLOG_MCP_AUTH_TOKEN}"
      }
    },
    "heroui-pro": {
      "url": "https://mcp.heroui.pro/mcp",
      "headers": {
        "x-heroui-personal-token": "${HEROUI_PERSONAL_TOKEN}"
      }
    },
    "heroui-react": {
      "command": "bunx",
      "args": ["-y", "@heroui/react-mcp@latest"]
    },
    "shadcn": {
      "command": "bunx",
      "args": ["shadcn@latest", "mcp"]
    }
  }
}
