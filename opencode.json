{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "blog": {
      "type": "remote",
      "url": "https://ruchern.dev/api/mcp",
      "headers": {
        "Authorization": "Bearer {env:BLOG_MCP_AUTH_TOKEN}"
      }
    },
    "heroui-pro": {
      "type": "remote",
      "url": "https://mcp.heroui.pro/mcp",
      "headers": {
        "x-heroui-personal-token": "{env:HEROUI_PERSONAL_TOKEN}"
      }
    },
    "posthog": {
      "type": "remote",
      "url": "https://mcp.posthog.com/mcp",
      "headers": {
        "Authorization": "Bearer {env:POSTHOG_PERSONAL_API_KEY}"
      }
    }
  }
}
