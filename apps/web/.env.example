NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Database Configuration
DATABASE_URL=

# GitHub Integration
GH_ACCESS_TOKEN=

# Redis Configuration
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# IP Salting
IP_SALT=

# BetterAuth Configuration
BETTER_AUTH_SECRET=
# For production, set it to something else. e.g. https://auth.example.com
BETTER_AUTH_URL="http://localhost:3000"

# OAuth Providers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudflare R2 Storage
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=https://assets.ruchern.dev

# PostHog (Vercel integration, EU Cloud)
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# PostHog Query API (server-side reads — separate from Vercel integration)
POSTHOG_PROJECT_ID=
POSTHOG_API_KEY=

# MCP Server (Remote Access)
# Static bearer for headless MCP/CLI clients (remote MCP server, usage:ingest:prod).
# Retained alongside OAuth; slated for removal once those clients migrate.
BLOG_MCP_AUTH_TOKEN=

# OAuth/OIDC Provider (@better-auth/oauth-provider's oauthProvider plugin + jwt())
# The app is its own OAuth 2.1 / OIDC provider. Clients authenticate users via
# the Authorization Code flow (PKCE required) and use the resulting access token
# as a bearer against protected routes. Public clients (no secret) are supported
# and clients self-register via the dynamic client registration endpoint.
# - Discovery: /api/auth/.well-known/openid-configuration
# - authorize: /api/auth/oauth2/authorize  | token: /api/auth/oauth2/token
# - register: /api/auth/oauth2/register
# The provider needs no extra env vars.
