  "type": "module",
  "private": true,
  "scripts": {
    "dev": "portless blog next dev",
    "build": "next build",
    "start": "portless blog next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "next typegen && tsc --noEmit",
    "auth:generate": "pnx auth@latest generate --config src/lib/auth.ts --output src/schema/auth.ts --yes",
    "db:drop": "drizzle-kit drop",
