{
  "$schema": "https://turborepo.com/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "BETTER_AUTH_*",
        "BLOG_MCP_AUTH_TOKEN",
        "CLOUDFLARE_ACCOUNT_ID",
        "DATABASE_URL",
        "GH_ACCESS_TOKEN",
        "GITHUB_CLIENT_*",
        "GOOGLE_CLIENT_*",
        "IP_SALT",
        "NEXT_PUBLIC_*",
        "POSTHOG_API_*",
        "POSTHOG_PROJECT_ID",
        "R2_*",
        "UPSTASH_REDIS_REST_*",
        "VERCEL_PROJECT_PRODUCTION_URL",
        "VERCEL_URL"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env",
        ".env.local",
        ".env.development.local",
        ".env.production",
        ".env.production.local"
      ],
      "outputs": [".next/**", "!.next/cache/**"]
    }
  }
}
