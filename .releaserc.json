{
  "tagFormat": "v${version}",
  "branches": ["main"],
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits"
      }
    ],
    [
      "@semantic-release/release-notes-generator",
      {
        "preset": "conventionalcommits"
      }
    ],
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "pnpm version ${nextRelease.version} --no-git-tag-version --no-git-checks && pnpm --dir apps/web version ${nextRelease.version} --no-git-tag-version --no-git-checks && pnpm --dir apps/docs version ${nextRelease.version} --no-git-tag-version --no-git-checks"
      }
    ],
    [
      "@semantic-release-extras/verified-git-commit",
      {
        "assets": [
          "package.json",
          "apps/web/package.json",
          "apps/docs/package.json",
          "CHANGELOG.md"
        ]
      }
    ],
    [
      "@semantic-release/github",
      {
        "releasedLabels": ["released"],
        "assignees": ["ruchernchong"]
      }
    ]
  ]
}
